{
  "name": "valentin-personal-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate && vite --host 0.0.0.0",
    "generate": "node scripts/generate-notes-index.mjs",
    "sync-notes": "node scripts/sync-notes.mjs && npm run generate",
